# Ollama Configuration - Best for High-Performance Workstation
LLM_AGENT_BACKEND=ollama
LLM_AGENT_ENDPOINT=http://localhost:11434/api/chat
LLM_AGENT_MODEL=llama3.2-vision
LLM_AGENT_TIMEOUT_S=30
LLM_AGENT_USE_VISION=1

# Alternative Models for Your Hardware:
# For faster inference: LLM_AGENT_MODEL=llama3.2-3b-vision
# For better reasoning: LLM_AGENT_MODEL=qwen2.5-7b-instruct
# For complex tasks: LLM_AGENT_MODEL=llama3.1-70b
