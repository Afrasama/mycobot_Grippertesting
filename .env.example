# Ollama Configuration
# Copy this file to .env and modify as needed

# Default Ollama Configuration
LLM_AGENT_BACKEND=ollama
LLM_AGENT_ENDPOINT=http://localhost:11434/api/chat
LLM_AGENT_MODEL=llama3.2-vision
LLM_AGENT_TIMEOUT_S=60
LLM_AGENT_USE_VISION=1

# Alternative Ollama Models (uncomment to use)
# LLM_AGENT_MODEL=llama3.2
# LLM_AGENT_MODEL=qwen2.5:7b
# LLM_AGENT_MODEL=deepseek-coder:6.7b
