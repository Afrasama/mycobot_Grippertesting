<?xml version="1.1"?>
<robot name="mycobot_320">

  <!-- base -->
  <link name="base">
    <visual>
      <geometry>
        <mesh filename="meshes/base.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
