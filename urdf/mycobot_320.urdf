    <collision>
      <geometry>
        <mesh filename="meshes/base.dae"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
    </collision>
  </link>

  <!-- link1 -->
  <link name="link1">
